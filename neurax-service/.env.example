## ------------------------------------------------------------
# Debug & Development (NEVER USE IN PRODUCTION)
# ------------------------------------------------------------

# Set to true to bypass email verification and shape inference gates
NEURAX_DEBUG_BYPASS=false
NEURAX_MOCK_PLAN=elite
# Mock the user's subscription tier (free, essential, architect, elite)
# Overrides whatever is in the database for the /me endpoint

# Bind address for Actix server
NEURAX_BIND=0.0.0.0:9098

# Supabase project URL
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase Service Role Key (backend only; used to call PostgREST)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ------------------------------------------------------------
# Stripe Billing (subscriptions)
# ------------------------------------------------------------

# Stripe secret key (server-side only)
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY

# Stripe webhook signing secret (from Stripe Dashboard or Stripe CLI `stripe listen`)
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET

# Where Stripe Customer Portal should send the user back after managing billing
STRIPE_PORTAL_RETURN_URL=http://localhost:8080/account

# Stripe Price IDs (recurring) mapped to plan tiers and billing intervals
STRIPE_PRICE_ESSENTIAL_MONTHLY=price_YOUR_PRICE_ID
STRIPE_PRICE_ESSENTIAL_ANNUAL=price_YOUR_PRICE_ID
STRIPE_PRICE_ARCHITECT_MONTHLY=price_YOUR_PRICE_ID
STRIPE_PRICE_ARCHITECT_ANNUAL=price_YOUR_PRICE_ID
STRIPE_PRICE_ELITE_MONTHLY=price_YOUR_PRICE_ID
STRIPE_PRICE_ELITE_ANNUAL=price_YOUR_PRICE_ID

