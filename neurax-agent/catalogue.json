{
  "cnn": {
    "description": "Convolutional Neural Networks for visual tasks",
    "taskHints": [
      "image classification",
      "object detection",
      "visual feature extraction",
      "image segmentation",
      "mobile deployment"
    ],
    "defaultInputShape": "[B, 3, 224, 224]",
    "blocks": [
      {
        "type": "input",
        "name": "Input",
        "defaultParams": {
          "shape": "[B, 3, 224, 224]"
        }
      },
      {
        "type": "output",
        "name": "Output",
        "defaultParams": {}
      },
      {
        "type": "conv2d",
        "name": "Conv2D",
        "defaultParams": {
          "in_channels": 3,
          "out_channels": 64,
          "kernel_size": 3,
          "stride": 1,
          "padding": 1,
          "bias": true
        }
      },
      {
        "type": "depthwise_conv2d",
        "name": "Depthwise Conv2D",
        "defaultParams": {
          "in_channels": 64,
          "kernel_size": 3,
          "stride": 1,
          "padding": 1,
          "groups": 64,
          "bias": false
        }
      },
      {
        "type": "se_block",
        "name": "Squeeze-and-Excitation Block",
        "defaultParams": {
          "channels": 64,
          "reduction_ratio": 16
        }
      },
      {
        "type": "max_pool",
        "name": "MaxPool2D",
        "defaultParams": {
          "pool_size": 2,
          "stride": 2
        }
      },
      {
        "type": "avg_pool",
        "name": "AvgPool2D",
        "defaultParams": {
          "pool_size": 2,
          "stride": 2
        }
      },
      {
        "type": "global_pool",
        "name": "Global Average Pool",
        "defaultParams": {}
      },
      {
        "type": "batchnorm",
        "name": "BatchNorm2D",
        "defaultParams": {
          "num_features": 64,
          "eps": 1e-05,
          "momentum": 0.1,
          "affine": true
        }
      },
      {
        "type": "instancenorm",
        "name": "InstanceNorm2D",
        "defaultParams": {
          "num_features": 64,
          "eps": 1e-05,
          "affine": false
        }
      },
      {
        "type": "groupnorm",
        "name": "GroupNorm",
        "defaultParams": {
          "num_groups": 32,
          "num_channels": 64,
          "eps": 1e-05
        }
      },
      {
        "type": "layernorm",
        "name": "LayerNorm",
        "defaultParams": {
          "normalized_shape": 64,
          "eps": 1e-05
        }
      },
      {
        "type": "dropout",
        "name": "Dropout",
        "defaultParams": {
          "p": 0.1
        }
      },
      {
        "type": "flatten",
        "name": "Flatten",
        "defaultParams": {}
      },
      {
        "type": "dense",
        "name": "Dense / Linear",
        "defaultParams": {
          "in_features": 512,
          "out_features": 256,
          "bias": true
        }
      },
      {
        "type": "relu",
        "name": "ReLU",
        "defaultParams": {}
      },
      {
        "type": "gelu",
        "name": "GELU",
        "defaultParams": {}
      },
      {
        "type": "silu",
        "name": "SiLU",
        "defaultParams": {}
      },
      {
        "type": "residual",
        "name": "Residual / Skip Connection",
        "defaultParams": {
          "projection": false
        }
      },
      {
        "type": "add",
        "name": "Element-wise Add",
        "defaultParams": {}
      },
      {
        "type": "concat",
        "name": "Concatenate",
        "defaultParams": {
          "axis": 1
        }
      },
      {
        "type": "merge",
        "name": "Merge",
        "defaultParams": {}
      },
      {
        "type": "classification_head",
        "name": "Classification Head",
        "defaultParams": {
          "in_features": 512,
          "num_classes": 10
        }
      }
    ],
    "macroBlocks": [
      {
        "id": "macro-resnet-block",
        "name": "ResNet Block",
        "description": "Conv2D → BN → ReLU → Conv2D → BN → (+Skip) → ReLU"
      },
      {
        "id": "macro-bottleneck",
        "name": "Bottleneck Block",
        "description": "1×1 Conv → 3×3 Conv → 1×1 Conv with residual"
      },
      {
        "id": "macro-mbconv",
        "name": "MBConv Block",
        "description": "Expand Conv → Depthwise Conv2D → SE Block → Project Conv"
      }
    ],
    "presets": [
      {
        "id": "cnn-lenet",
        "name": "LeNet-5",
        "description": "Classic CNN for digit recognition"
      },
      {
        "id": "cnn-resnet",
        "name": "ResNet-50",
        "description": "Deep residual network with skip connections"
      },
      {
        "id": "cnn-vgg",
        "name": "VGG-16",
        "description": "Very deep CNN with 3×3 convolutions"
      },
      {
        "id": "cnn-mobilenet",
        "name": "MobileNetV2",
        "description": "Inverted residuals for mobile devices"
      }
    ],
    "constraints": {
      "requiredBlocks": [
        "input",
        "output",
        "conv2d"
      ],
      "incompatibleBlocks": [
        "mha",
        "mha",
        "gqa",
        "expert",
        "gate",
        "mamba_block",
        "s4_block",
        "gcn_conv",
        "gat_conv",
        "sage_conv",
        "lstm",
        "gru",
        "bilstm"
      ]
    }
  },
  "transformer": {
    "description": "Transformer architectures for sequence modeling",
    "taskHints": [
      "text generation",
      "language modeling",
      "translation",
      "text classification",
      "sequence-to-sequence"
    ],
    "defaultInputShape": "[B, seq_len]",
    "blocks": [
      {
        "type": "input",
        "name": "Input",
        "defaultParams": {
          "shape": "[B, seq_len]"
        }
      },
      {
        "type": "output",
        "name": "Output",
        "defaultParams": {}
      },
      {
        "type": "embedding",
        "name": "Token Embedding",
        "defaultParams": {
          "vocab_size": 32000,
          "d_model": 512,
          "padding_idx": 0
        }
      },
      {
        "type": "positional_encoding",
        "name": "Positional Encoding (sinusoidal)",
        "defaultParams": {
          "max_seq_len": 2048,
          "d_model": 512,
          "dropout": 0.1
        }
      },
      {
        "type": "rope",
        "name": "Rotary Position Embedding (RoPE)",
        "defaultParams": {
          "dim": 64,
          "base": 10000
        }
      },
      {
        "type": "alibi",
        "name": "ALiBi Position Bias",
        "defaultParams": {
          "num_heads": 8
        }
      },
      {
        "type": "mha",
        "name": "Multi-Head Attention",
        "defaultParams": {
          "num_heads": 8,
          "d_model": 512,
          "head_dim": 64,
          "dropout": 0.0,
          "bias": true,
          "causal": false,
          "use_kv_cache": false
        }
      },
      {
        "type": "gqa",
        "name": "Grouped Query Attention",
        "defaultParams": {
          "num_heads": 8,
          "num_kv_heads": 2,
          "d_model": 512,
          "head_dim": 64,
          "dropout": 0.0,
          "causal": true,
          "use_kv_cache": false
        }
      },
      {
        "type": "layernorm",
        "name": "LayerNorm",
        "defaultParams": {
          "normalized_shape": 512,
          "eps": 1e-05
        }
      },
      {
        "type": "rmsnorm",
        "name": "RMSNorm",
        "defaultParams": {
          "normalized_shape": 512,
          "eps": 1e-06
        }
      },
      {
        "type": "ffn",
        "name": "Feed-Forward Network",
        "defaultParams": {
          "d_model": 512,
          "hidden_dim": 2048,
          "activation": "relu",
          "dropout": 0.0,
          "bias": true
        }
      },
      {
        "type": "swiglu",
        "name": "SwiGLU FFN",
        "defaultParams": {
          "d_model": 512,
          "hidden_dim": 2048,
          "bias": false,
          "dropout": 0.0
        }
      },
      {
        "type": "dropout",
        "name": "Dropout",
        "defaultParams": {
          "p": 0.1
        }
      },
      {
        "type": "residual",
        "name": "Residual Connection",
        "defaultParams": {
          "projection": false
        }
      },
      {
        "type": "add",
        "name": "Element-wise Add",
        "defaultParams": {}
      },
      {
        "type": "lm_head",
        "name": "LM Head",
        "defaultParams": {
          "in_features": 512,
          "vocab_size": 32000,
          "weight_tying": true,
          "bias": false
        }
      },
      {
        "type": "classification_head",
        "name": "Classification Head",
        "defaultParams": {
          "in_features": 512,
          "num_classes": 10
        }
      }
    ],
    "macroBlocks": [
      {
        "id": "macro-transformer-block",
        "name": "Standard Transformer Block",
        "description": "LayerNorm → MHA → Residual → LayerNorm → FFN → Residual"
      },
      {
        "id": "macro-decoder-block",
        "name": "Decoder-Only Block",
        "description": "RMSNorm → GQA (causal) → Residual → RMSNorm → SwiGLU → Residual"
      },
      {
        "id": "macro-cross-attn",
        "name": "Cross-Attention Block",
        "description": "LayerNorm → Cross-MHA → Residual (encoder-decoder)"
      }
    ],
    "presets": [
      {
        "id": "gpt-style",
        "name": "GPT-style (Decoder-Only)",
        "description": "Autoregressive decoder with causal masking"
      },
      {
        "id": "bert-style",
        "name": "BERT-style (Encoder-Only)",
        "description": "Bidirectional encoder for representation learning"
      },
      {
        "id": "llama-style",
        "name": "LLaMA-style",
        "description": "Efficient decoder with RMSNorm, GQA, SwiGLU and RoPE"
      }
    ],
    "constraints": {
      "requiredBlocks": [
        "input",
        "output",
        "mha"
      ],
      "incompatibleBlocks": [
        "gcn_conv",
        "gat_conv",
        "sage_conv",
        "mamba_block",
        "s4_block",
        "lstm",
        "gru",
        "bilstm",
        "conv2d"
      ]
    }
  },
